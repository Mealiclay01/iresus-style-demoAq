          "text": "Call resuscitation team / ambulance",
          "icon": "clipboard"
        },
        {
          "id": "als_3",
          "type": "step",
          "color": "grey",
          "text": "CPR 30:2 • Attach defibrillator/monitor",
          "icon": "camera",
          "image": {
            "url": "./assets/images/airway_ref.svg",
            "caption": "Airway management reference"
          }
        },
        {
          "id": "als_4",
