      "drugsCards": [
        {
          "name": "Adrenaline (Epinephrine)",
          "dose": "1 mg IV/IO",
          "route": "Intravenous or Intraosseous",
          "notes": "Give after 3rd shock for shockable rhythms. Repeat every 3-5 minutes during CPR."
        },
        {
          "name": "Amiodarone",
          "dose": "300 mg IV/IO",
          "route": "Intravenous or Intraosseous",
          "notes": "After 3 shocks if VF/pVT persists. Second dose of 150 mg can be given."
        },
        {
          "name": "Atropine",
          "dose": "500 mcg IV",
          "route": "Intravenous",
          "notes": "No longer recommended in cardiac arrest management."
        }
      ],
      "notesMarkdown": "### Reversible Causes (4 Hs & 4 Ts)\n\n- Hypoxia\n- Hypovolemia\n- Hypo/hyperkalemia & metabolic disorders\n- Hypothermia\n- Thrombosis (coronary or pulmonary)\n- Tamponade (cardiac)\n- Toxins\n- Tension pneumothorax\n\n### Key Points\n\nMinimize interruptions in chest compressions. Ensure high-quality CPR throughout. Consider mechanical CPR devices if available. Monitor ETCO2 if capnography available.",
      "steps": [
        {
          "id": "als_1",
          "type": "header",
          "color": "blue",
          "text": "Unresponsive and not breathing normally",
          "icon": "camera",
          "image": {
